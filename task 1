<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Simple Web Page</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            font-family:Arial, sans-serif;
            background:#f4f4f4;
        }

        header{
            background:#0077cc;
            color:white;
            text-align:center;
            padding:20px;
        }

        nav{
            background:#333;
            text-align:center;
            padding:10px;
        }

        nav a{
            color:rgb(223, 216, 216);
            text-decoration:none;
            margin:0 15px;
            font-size:18px;
        }

        nav a:hover{
            color:yellow;
        }

        .container{
            width:80%;
            margin:30px auto;
            background:white;
            padding:30px;
            border-radius:10px;
            box-shadow:0 0 10px rgba(0,0,0,0.2);
        }

        h2{
            color:#0077cc;
            margin-bottom:15px;
        }

        p{
            line-height:1.8;
            margin-bottom:20px;
        }

        button{
            background:#0077cc;
            color:white;
            border:none;
            padding:10px 20px;
            font-size:16px;
            border-radius:5px;
            cursor:pointer;
        }

        button:hover{
            background:#005fa3;
        }

        footer{
            background:#333;
            color:white;
            text-align:center;
            padding:15px;
            margin-top:30px;
        }
    </style>
</head>
<body>

<header>
    <h1>Welcome to My Website</h1>
    <p>Simple HTML & CSS Web Page</p>
</header>

<nav>
    <a href="#">Home</a>
    <a href="#">About</a>
    <a href="#">Services</a>
    <a href="#">Contact</a>
</nav>

<div class="container">
    <h2>About This Website</h2>

    <p>
        This is a simple webpage created using only HTML and CSS.
        It demonstrates basic webpage structure including a header,
        navigation menu, content section, button, and footer.
    </p>

    <button>Learn More</button>
</div>

<footer>
    <p>&copy; 2026 My Website. All Rights Reserved.</p>
</footer>

</body>
</html>